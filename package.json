{
  "name": "study-in-china-simulator",
  "version": "1.0.0",
  "description": "Standalone HTML Prototype for Study in China Simulator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "qa:routes": "node tools/route_full_qa.mjs",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "author": "silverlion2",
  "repository": "silverlion2/study_in_china_simulator",
  "keywords": [
    "study-in-china",
    "simulator",
    "indie-game",
    "react-game",
    "electron-app",
    "life-simulation",
    "visual-novel",
    "rpg",
    "educational-game"
  ],
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.silverlion2.studysimulator",
    "productName": "Sim Panda",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "directories": {
      "output": "dist"
    }
  }
}
